<!-- index.html -->
<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>BeautyGlow</title>

  <!-- FONT -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="style.css">
</head>

<body>

  <!-- HEADER -->

  <header>

    <div class="logo">
      BeautyGlow
    </div>

    <nav>
	  <a href="#home">Home</a>
	  <a href="#tutorial">Tutorial</a>
	  <a href="#skincare">Skincare</a>
	  <a href="#blog">Blog</a>
	</nav>

  </header>

  <!-- MAIN -->

  <main>

    <!-- HERO SECTION -->

    <section class="hero" id="home">

      <div class="hero-text">

        <h1>
          Il makeup perfetto<br>
          per ogni occasione
        </h1>

        <p>
          Tutorial beauty personalizzati in base
          al tuo evento e tipo di pelle
        </p>

        <button>
          Scopri i Tutorial
        </button>

      </div>

    </section>

    <!-- FILTRI -->

    <section class="filters">

      <h2>Trova il tuo makeup ideale</h2>

      <div class="filter-container">

        <select id="evento">

          <option value="all">
            Tutti gli eventi
          </option>

          <option value="matrimonio">
            Matrimonio
          </option>

          <option value="compleanno">
            Compleanno
          </option>

          <option value="battesimo">
            Battesimo
          </option>

          <option value="quotidiano">
            Quotidiano
          </option>

        </select>

        <select id="pelle">

          <option value="all">
            Tutti i tipi di pelle
          </option>

          <option value="secca">
            Pelle secca
          </option>

          <option value="mista">
            Pelle mista
          </option>

          <option value="grassa">
            Pelle grassa
          </option>

        </select>

      </div>

    </section>

    <!-- TUTORIAL -->

    <section class="tutorial-section" id="tutorial">

      <h2>Tutorial Consigliati</h2>

      <div class="tutorial-container">

        <!-- CARD 1 -->

        <div class="card"
		data-evento="matrimonio"
		data-pelle="secca">

		<img src="images/wedding.jpg" alt="makeup">

		<div class="card-content">

			<h3>Soft Glam Wedding</h3>

			<p>
			Makeup glow elegante per pelle secca.
			</p>

			<span>
			Matrimonio • Pelle Secca
			</span>

			<iframe
			  width="100%"
			  height="220"
			  src="https://www.youtube.com/embed/o5TL24kpk3M"
			  title="Wedding Makeup Tutorial"
			  frameborder="0"
			  allowfullscreen>
			</iframe>

		</div>

</div>
          </div>

        </div>

        <!-- CARD 2 -->
		<div class="card"
		data-evento="compleanno"
		data-pelle="mista">

		  <img src="images/party.jpg" alt="party makeup">

		  <div class="card-content">

			<h3>Party Glam</h3>

			<p>
			  Look luminoso lunga durata.
			</p>

			<span>
			  Compleanno • Pelle Mista
			</span>

			<iframe
			  width="100%"
			  height="220"
			  src="https://www.youtube.com/embed/7x8iQhW1jzQ"
			  title="Party Glam Makeup"
			  frameborder="0"
			  allowfullscreen>
			</iframe>

		</div>

</div>
       

        <!-- CARD 3 -->
		<div class="card"
		data-evento="quotidiano"
		data-pelle="grassa">

		  <img src="images/daily.jpg" alt="daily makeup">

		  <div class="card-content">

			<h3>Daily Matte Look</h3>

			<p>
			  Trucco naturale anti lucidità.
			</p>

			<span>
			  Quotidiano • Pelle Grassa
			</span>

			<iframe
			  width="100%"
			  height="220"
			  src="https://www.youtube.com/embed/fCCfUwsAqOw"
			  title="Daily Matte Makeup"
			  frameborder="0"
			  allowfullscreen>
			</iframe>

		  </div>

</div>
        

        </div>

      </div>

    </section>

    <!-- SKINCARE -->

    <section class="skincare" id="skincare">

      <h2>Skincare Consigliata</h2>

      <div class="skin-container">

        <div class="skin-box">

          <h3>Pelle Secca</h3>

          <p>
            Crema idratante, primer glow e siero all’acido ialuronico.
          </p>

          <a href="https://www.sephora.it" target="_blank">
            Scopri Prodotti
          </a>

        </div>

        <div class="skin-box">

          <h3>Pelle Grassa</h3>

          <p>
            Cleanser oil-free e primer opacizzante.
          </p>

          <a href="https://www.sephora.it" target="_blank">
            Scopri Prodotti
          </a>

        </div>

      </div>

    </section>

    <!-- MAKEUP ARTIST -->

    <section class="artists" id="blog">

      <h2>Ispirazione Makeup Artist</h2>

      <div class="artist-container">

        <div class="artist-card">
          <h3>Charlotte Tilbury</h3>
         
		 <img src="images/charlotte.jpg" alt="Charlotte Tilbury">
           <p>
		   Glow makeup elegante e luminoso.
          </p>
        </div>

        <div class="artist-card">
          <h3>Mario Dedivanovic</h3>
		  <img src="images/mario.jpg" alt="Mario Dedivanovic">
          <p>
            Soft glam e makeup fotografico.
          </p>
        </div>

      </div>

    </section>

  </main>

  <!-- FOOTER -->

  <footer>

    <p>
      BeautyGlow © 2026
    </p>

    <p>
      Tutorial beauty • Makeup • Skincare
    </p>

  </footer>

  <script src="script.js"></script>

</body>
</html>
